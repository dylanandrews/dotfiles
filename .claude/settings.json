{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Read(/Users/dylanandrews/.claude/*)",
      "Write(/Users/dylanandrews/Dropbox/betterup_obsidian_vault/*)",
      "Edit(/Users/dylanandrews/Dropbox/betterup_obsidian_vault/*)",
      "Write(/Users/dylanandrews/Documents/betterup_repos/ai-workbench/*)",
      "Edit(/Users/dylanandrews/Documents/betterup_repos/ai-workbench/*)",
      "Bash(bin/codeownership:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(tail:*)",
      "Bash(cat:*)",
      "Bash(wc:*)",
      "Bash(awk:*)",
      "Bash(tree:*)",
      "Bash(python3:*)",
      "Bash(gh api:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(jq:*)",
      "Bash(git fetch:*)",
      "Bash(docker ps:*)",
      "Bash(docker logs:*)",
      "Bash(bundle show:*)",
      "Bash(bin/rake:*)",
      "Bash(bin/bundle:*)",
      "Bash(mkdir:*)",
      "Bash(ls:*)",
      "Bash(bash -c:*)",
      "Bash(for:*)",
      "Bash(echo:*)",
      "Bash(pbcopy:*)",
      "Bash(codex:*)",
      "Bash(gemini:*)"
    ],
    "additionalDirectories": [
      "/Users/dylanandrews/Dropbox/betterup_obsidian_vault/"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Blow.aiff"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Hero.aiff"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude-code-docs/claude-docs-helper.sh hook-check"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "beads@beads-marketplace": false,
    "example-skills@anthropic-agent-skills": true,
    "learning-output-style@claude-code-plugins": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "codex@openai-codex": false,
    "superpowers@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-code-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-code"
      }
    },
    "betterup-engineering": {
      "source": {
        "source": "github",
        "repo": "betterup/betterup-claude-code-toolkit"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true
}
