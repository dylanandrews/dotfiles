{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "deny": [
      "Bash(git push --force)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push origin +*)",
      "Bash(git reset --hard *)",
      "Bash(git reset --hard)",
      "Bash(curl *//github.com/*)",
      "Bash(curl *//api.github.com/*)",
      "Bash(curl *//raw.githubusercontent.com/*)",
      "Bash(gh auth token *)",
      "Bash(gh auth token)",
      "Bash(npm *)",
      "Bash(npm)"
    ],
    "allow": [
      "Read(/Users/dylanandrews/.claude/*)",
      "Write(/Users/dylanandrews/Dropbox/betterup_obsidian_vault/*)",
      "Edit(/Users/dylanandrews/Dropbox/betterup_obsidian_vault/*)",
      "Write(/Users/dylanandrews/Documents/betterup_repos/ai-workbench/*)",
      "Edit(/Users/dylanandrews/Documents/betterup_repos/ai-workbench/*)",

      "Edit",
      "MultiEdit",
      "Write",
      "WebFetch(domain:app.trunk.io)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:www.anthropic.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:gist.github.com)",
      "WebFetch(domain:betterup.atlassian.net)",
      "WebFetch(domain:api.atlassian.com)",
      "WebFetch(domain:developer.atlassian.com)",
      "WebSearch",

      "Bash(.github/scripts/get-check-annotations *)",
      "Bash(.github/scripts/run-rspec-repeat *)",
      "Bash(bin/bundle-audit *)",
      "Bash(bin/bundle:*)",
      "Bash(bin/codeownership:*)",
      "Bash(./packs/code_ownership_extensions/bin/cli *)",
      "Bash(bin/dc:*)",
      "Bash(bin/packwerk:*)",
      "Bash(bin/quarantine:*)",
      "Bash(bin/setup:*)",
      "Bash(bin/setup)",
      "Bash(bin/rails:*)",
      "Bash(bin/rake:*)",
      "Bash(bin/rspec:*)",
      "Bash(bin/rubocop:*)",
      "Bash(bin/test-changes:*)",
      "Bash(bin/test-changes)",
      "Bash(bin/utils/ci/check-migrations-consistency *)",
      "Bash(bin/utils/codespace/check-status *)",
      "Bash(bin/utils/codespace/list-sessions *)",
      "Bash(bin/utils/codespace/view-logs *)",
      "Bash(bin/utils/codespace/cleanup *)",
      "Bash(bin/utils/codespace/codespace-exec *)",
      "Bash(bin/utils/codespace/create-worker *)",
      "Bash(bin/utils/codespace/send-task *)",
      "Bash(bin/utils/codespace/start-orchestrator *)",
      "Bash(bin/utils/codespace/start-worker *)",
      "Bash(bundle exec bin/ff *)",

      "Bash(awk:*)",
      "Bash(bash -c:*)",
      "Bash(cat:*)",
      "Bash(cd:*)",
      "Bash(command:*)",
      "Bash(cp:*)",
      "Bash(date:*)",
      "Bash(date)",
      "Bash(docker-compose:*)",
      "Bash(docker:*)",
      "Bash(echo:*)",
      "Bash(env:*)",
      "Bash(env)",
      "Bash(exit:*)",
      "Bash(exit)",
      "Bash(export:*)",
      "Bash(find:*)",
      "Bash(for:*)",
      "Bash(do echo:*)",
      "Bash(done)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(ls)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(node:*)",
      "Bash(pwd)",
      "Bash(rg:*)",
      "Bash(sed:*)",
      "Bash(seq:*)",
      "Bash(sleep:*)",
      "Bash(sort:*)",
      "Bash(tail:*)",
      "Bash(tee:*)",
      "Bash(test:*)",
      "Bash(timeout:*)",
      "Bash(tr:*)",
      "Bash(tree:*)",
      "Bash(unlink:*)",
      "Bash(unset:*)",
      "Bash(unzip:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(xmllint:*)",
      "Bash(yamllint:*)",

      "Bash(git:*)",

      "Bash(gh:*)",

      "Bash(npx:*)",

      "Bash(acli:*)",
      "Bash(bundle:*)",
      "Bash(chmod:*)",
      "Bash(claude:*)",
      "Bash(curl:*)",
      "Bash(mdfind:*)",
      "Bash(mise:*)",
      "Bash(pbcopy:*)",
      "Bash(python3:*)",
      "Bash(ruby:*)",
      "Bash(sqlite3:*)",
      "Bash(xargs:*)",
      "Bash(codex:*)",
      "Bash(gemini:*)",
      "Bash(rm:*)",

      "Bash(yarn:*)",

      "Glob",
      "Grep",
      "Read"
    ],
    "additionalDirectories": [
      "/Users/dylanandrews/Dropbox/betterup_obsidian_vault/"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Blow.aiff"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Hero.aiff"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude-code-docs/claude-docs-helper.sh hook-check"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "beads@beads-marketplace": false,
    "example-skills@anthropic-agent-skills": true,
    "learning-output-style@claude-code-plugins": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "codex@openai-codex": false,
    "superpowers@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-code-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-code"
      }
    },
    "betterup-engineering": {
      "source": {
        "source": "github",
        "repo": "betterup/betterup-claude-code-toolkit"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true
}
